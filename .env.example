# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Stack Names
STACK_PREFIX=notification-platform
ENVIRONMENT=dev

# MSK (preenchido após deploy)
MSK_BOOTSTRAP_SERVERS=

# Kafka Topics
KAFKA_TOPIC_EVENTS=notification.events
KAFKA_TOPIC_DLQ=notification.dlq

# SES (para email worker)
SES_FROM_EMAIL=no-reply@yourdomain.com

# SNS ARNs (preenchidos após deploy)
SNS_NOTIFICATION_TOPIC_ARN=

# Step Functions ARN (preenchido após deploy)
STEP_FUNCTIONS_STATE_MACHINE_ARN=
